{
  "models": {
    "_comment": "所有模型的绝对路径，asr/vad/punc 的 model 字段引用此处的 key",
    "asr_seaco_gpu": "D:/arvin/obsidian_workpace/models/iic/speech_seaco_paraformer_large_asr_nat-zh-cn-16k-common-vocab8404-pytorch",
    "asr_paraformer_onnx": "D:/arvin/obsidian_workpace/models/iic/speech_paraformer-large_asr_nat-zh-cn-16k-common-vocab8404-onnx",
    "vad_fsmn_pytorch": "D:/arvin/obsidian_workpace/models/iic/speech_fsmn_vad_zh-cn-16k-common-pytorch",
    "vad_fsmn_onnx": "D:/arvin/obsidian_workpace/models/vad_damo/damo/speech_fsmn_vad_zh-cn-16k-common-onnx",
    "punc_ct_pytorch": "D:/arvin/obsidian_workpace/models/iic/punc_ct-transformer_cn-en-common-vocab471067-large",
    "punc_ct_onnx": "D:/arvin/obsidian_workpace/models/punc_damo/damo/punc_ct-transformer_cn-en-common-vocab471067-large-onnx"
  },

  "asr": {
    "_comment": "model 引用 models 段中的 key；engine: funasr(GPU) 或 onnx(CPU)",
    "model": "asr_paraformer_onnx",
    "engine": "onnx",
    "device": "cpu",
    "hotwords_enabled": false,
    "intra_op_threads": 4
  },

  "vad": {
    "_comment": "model 引用 models 段中的 key；mode: fsmn_vad | sensevoice | simple",
    "model": "vad_fsmn_pytorch",
    "enabled": true,
    "mode": "fsmn_vad",
    "threshold": 0.5,
    "min_speech_duration": 0.3,
    "max_speech_duration": 4.0,
    "silence_timeout": 2.0,
    "pre_roll_duration": 0.1,
    "post_roll_duration": 0.1
  },

  "punc": {
    "_comment": "model 引用 models 段中的 key",
    "model": "punc_ct_onnx",
    "enabled": true
  },

  "text_processor": {
    "punctuation": "。！？.!?",
    "split_punctuation": "，。！？.!?",
    "silence_threshold": 2,
    "max_accumulate": 6.0,
    "check_interval": 3.0,
    "dedup_window": 5.0
  }
}
